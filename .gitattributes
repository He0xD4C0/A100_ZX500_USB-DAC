# ─── 文本文件自动换行处理 ────────────────────────────────────
* text=auto

# ─── 二进制文件标记 (不要 diff / 换行转换) ─────────────────
Image.gz     binary
*.webp       binary
*.jar        binary
*.png        binary
*.jpg        binary
*.jpeg       binary

# ─── Shell 脚本使用 LF ──────────────────────────────────────
*.sh         text eol=lf
init.usb_dac.rc text eol=lf
