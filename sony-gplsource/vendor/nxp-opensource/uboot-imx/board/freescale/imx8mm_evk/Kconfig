if TARGET_IMX8MM_EVK || TARGET_IMX8MM_DDR4_EVK

config SYS_BOARD
	default "imx8mm_evk"

config SYS_VENDOR
	default "freescale"

config SYS_CONFIG_NAME
	default "imx8mm_evk"

config ICX_OTG_ALL_SUSPEND
	bool "Suspend all OTG channel at boot"
	default n
	help
	  Say Y to suspend all OTG channels at boot.
	  It may reduce power consumption at kernel suspend.
	  Especially, kernel doesn't use one or more OTG channel.
	  Note: Fastboot is still available (updating firmware by uuu).
	  Say N to don't suspend OTG channgels at boot.
	  Use this option when enable all OTG channel by kernel.

source "board/freescale/common/Kconfig"

endif
