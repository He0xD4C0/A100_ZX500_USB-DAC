#
# init.usb_dac.rc — USB DAC 原生守护进程
#
# 启动 dacd（单一原生 daemon，取代 usb_dac_ctl.sh + uac2_bridge）
# Activity 通过 Unix socket 与 daemon 通信，无需 su。
#
# 部署:
#   adb push dacd /vendor/bin/
#   adb push init.usb_dac.rc /vendor/etc/init/
#   adb shell chmod 755 /vendor/bin/dacd
#   reboot
#
# 依赖:
#   - 内核已编译 UAC2 gadget 支持 (f_uac2)
#   - configfs 已挂载
#

on early-boot
    # UAC2 内核模块已直接编译进内核，无需 insmod

service dacd /vendor/bin/dacd -f
    class main
    user root
    group root system
    seclabel u:r:su:s0
    # dacd 自行管理 Unix socket（/data/local/tmp/dacd.sock）
    oneshot
    # 开机启动，崩溃后不自动重启（避免 configfs 半状态残留）

on early-boot
    # UAC2 内核模块已直接编译进内核，无需 insmod

on boot
    start dacd
